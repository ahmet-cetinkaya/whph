<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>me.ahmetcetinkaya.whph</id>
  <name>Work Hard Play Hard</name>
  <summary>A comprehensive productivity app designed to help you manage tasks, develop new habits, and optimize your time</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  
  <description>
    <p>
      WHPH (Work Hard Play Hard) is a comprehensive productivity application that helps you manage your daily tasks, develop new habits, and optimize your time effectively. Built with Flutter for cross-platform compatibility, it offers a clean and intuitive interface for productivity management.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Task management with tags and time tracking</li>
      <li>Habit tracking and development</li>
      <li>Notes organization with markdown support</li>
      <li>App usage monitoring and statistics</li>
      <li>Calendar integration</li>
      <li>Data synchronization across devices</li>
      <li>Customizable themes and settings</li>
      <li>Export and import functionality</li>
    </ul>
  </description>
  
